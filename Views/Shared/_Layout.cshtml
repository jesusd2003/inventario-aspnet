<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>@ViewData["Title"] - Inventario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <style>
        body{background:#f0f2f5}.navbar-brand{font-weight:800;letter-spacing:1px}
        .sidebar{min-height:calc(100vh - 56px);background:#1e293b}
        .sidebar .sec{color:#64748b;font-size:.68rem;text-transform:uppercase;padding:18px 18px 4px;letter-spacing:1.5px}
        .sidebar .nav-link{color:#94a3b8;padding:9px 18px;border-radius:6px;margin:1px 8px}
        .sidebar .nav-link:hover,.sidebar .nav-link.active{color:#fff;background:#334155}
        .sidebar .nav-link i{margin-right:8px;width:16px}
        .card-d{border:none;border-radius:14px;box-shadow:0 1px 6px rgba(0,0,0,.08)}
        .badge-pos{background:#6366f1}.badge-directa{background:#0ea5e9}
        .badge-contado{background:#22c55e}.badge-credito{background:#f59e0b}
    </style>
</head>
<body>
<nav class="navbar navbar-dark px-4" style="background:#1e293b">
    <span class="navbar-brand"><i class="bi bi-box-seam me-2"></i>Inventario Pro</span>
    @if (Context.Session.GetString("UserName") != null) {
        <div class="d-flex align-items-center gap-3">
            <span class="text-light small"><i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UserName")</span>
            <a href="/Login/Logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right me-1"></i>Salir</a>
        </div>
    }
</nav>
<div class="container-fluid"><div class="row">
@if (Context.Session.GetString("UserName") != null) {
    <nav class="col-md-2 d-none d-md-block sidebar py-2">
        <ul class="nav flex-column">
            <div class="sec">Inventario</div>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Productos"?"active":"")" href="/Productos"><i class="bi bi-archive"></i>Productos</a></li>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Categorias"?"active":"")" href="/Categorias"><i class="bi bi-tags"></i>Categorias</a></li>
            <div class="sec">Ventas</div>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Ventas"&&ViewContext.RouteData.Values["action"]?.ToString()=="Create"?"active":"")" href="/Ventas/Create"><i class="bi bi-plus-circle"></i>Nueva Venta</a></li>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Ventas"&&ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")" href="/Ventas"><i class="bi bi-receipt"></i>Historial</a></li>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Ventas"&&ViewContext.RouteData.Values["action"]?.ToString()=="Reportes"?"active":"")" href="/Ventas/Reportes"><i class="bi bi-bar-chart"></i>Reportes</a></li>
            <div class="sec">Clientes</div>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Clientes"?"active":"")" href="/Clientes"><i class="bi bi-people"></i>Clientes</a></li>
            <div class="sec">Compras</div>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Compras"&&ViewContext.RouteData.Values["action"]?.ToString()=="Create"?"active":"")" href="/Compras/Create"><i class="bi bi-cart-plus"></i>Nueva Compra</a></li>
            <li><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Compras"&&ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")" href="/Compras"><i class="bi bi-cart3"></i>Historial</a></li>
        </ul>
    </nav>
    <main class="col-md-10 ms-sm-auto px-4 py-4">
        @if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @RenderBody()
    </main>
} else { <main class="col-12">@RenderBody()</main> }
</div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>