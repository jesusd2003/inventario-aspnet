@model InventarioApp.Models.LoginViewModel
@{ ViewData["Title"]="Login"; Layout="_Layout"; }
<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:linear-gradient(135deg,#1e293b,#0f172a)">
    <div class="card card-d" style="width:100%;max-width:420px">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width:64px;height:64px;background:#1e293b">
                    <i class="bi bi-box-seam text-white fs-3"></i>
                </div>
                <h4 class="fw-bold">Inventario Pro</h4>
                <p class="text-muted small">Inicia sesion para continuar</p>
            </div>
            @if (!ViewData.ModelState.IsValid) { <div class="alert alert-danger small">@Html.ValidationSummary(false,"",new{@class="mb-0"})</div> }
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-envelope"></i></span><input asp-for="Correo" class="form-control" placeholder="admin@inventario.com"/></div>
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-lock"></i></span><input asp-for="Password" class="form-control" placeholder="Contrasena"/></div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn w-100 py-2 fw-semibold text-white" style="background:#1e293b"><i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesion</button>
            </form>
            <hr class="my-4"/>
            <p class="text-center text-muted small mb-0">Demo: <strong>admin@inventario.com</strong> / <strong>admin123</strong></p>
        </div>
    </div>
</div>