@model InventarioApp.Models.Producto
@{ ViewData["Title"]="Editar Producto"; }
<div class="d-flex align-items-center mb-4"><a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a><h2 class="fw-bold mb-0">Editar: @Model.Nombre</h2></div>
<div class="row justify-content-center"><div class="col-md-7"><div class="card card-d"><div class="card-body p-4">
    <form asp-action="Edit" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Id"/>
        <div class="mb-3"><label asp-for="Nombre" class="form-label fw-semibold"></label><input asp-for="Nombre" class="form-control"/><span asp-validation-for="Nombre" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Descripcion" class="form-label fw-semibold"></label><textarea asp-for="Descripcion" class="form-control" rows="2"></textarea></div>
        <div class="row">
            <div class="col-md-6 mb-3"><label asp-for="Precio" class="form-label fw-semibold"></label><div class="input-group"><span class="input-group-text">$</span><input asp-for="Precio" class="form-control" step="0.01"/></div><span asp-validation-for="Precio" class="text-danger small"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="Stock" class="form-label fw-semibold"></label><input asp-for="Stock" class="form-control" min="0"/><span asp-validation-for="Stock" class="text-danger small"></span></div>
        </div>
        <div class="mb-4"><label asp-for="CategoriaId" class="form-label fw-semibold"></label><select asp-for="CategoriaId" asp-items="ViewBag.CategoriaId" class="form-select"><option value="">-- Categoria --</option></select><span asp-validation-for="CategoriaId" class="text-danger small"></span></div>
        <div class="d-flex gap-2"><button type="submit" class="btn btn-dark px-4"><i class="bi bi-check-lg me-1"></i>Guardar</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
    </form>
</div></div></div></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }