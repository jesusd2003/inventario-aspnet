@model InventarioApp.Models.Producto
@{ ViewData["Title"]="Nuevo Producto"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title mb-0"><i class="bi bi-plus-circle"></i>Nuevo Producto</h1>
        <p class="page-subtitle mb-0">Agrega un nuevo producto al inventario</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card-modern">
            <div class="card-body p-4 p-lg-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-4">
                        <label asp-for="Nombre" class="form-label-modern">
                            <i class="bi bi-tag me-1"></i>Nombre del producto
                        </label>
                        <input asp-for="Nombre" class="form-control form-control-modern" placeholder="Ej: Laptop HP Pavilion" autofocus/>
                        <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Descripcion" class="form-label-modern">
                            <i class="bi bi-text-left me-1"></i>Descripcion (opcional)
                        </label>
                        <textarea asp-for="Descripcion" class="form-control form-control-modern" rows="3" placeholder="Descripcion detallada del producto..."></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="Precio" class="form-label-modern">
                                <i class="bi bi-currency-dollar me-1"></i>Precio de venta
                            </label>
                            <div class="input-group-modern">
                                <span class="input-group-text">$</span>
                                <input asp-for="Precio" class="form-control" step="0.01" placeholder="0.00"/>
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="Stock" class="form-label-modern">
                                <i class="bi bi-boxes me-1"></i>Stock inicial
                            </label>
                            <input asp-for="Stock" class="form-control form-control-modern" min="0" placeholder="0"/>
                            <span asp-validation-for="Stock" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="CategoriaId" class="form-label-modern">
                            <i class="bi bi-folder me-1"></i>Categoria
                        </label>
                        <select asp-for="CategoriaId" asp-items="ViewBag.CategoriaId" class="form-select form-select-modern">
                            <option value="">-- Selecciona una categoria --</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <hr class="my-4"/>
                    
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-modern-primary px-4">
                            <i class="bi bi-check-lg me-2"></i>Guardar Producto
                        </button>
                        <a asp-action="Index" class="btn btn-modern-outline">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
