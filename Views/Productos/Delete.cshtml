@model InventarioApp.Models.Producto
@{ ViewData["Title"]="Eliminar Producto"; }
<div class="d-flex align-items-center mb-4"><a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a><h2 class="fw-bold mb-0 text-danger"><i class="bi bi-trash me-2"></i>Eliminar Producto</h2></div>
<div class="row justify-content-center"><div class="col-md-6"><div class="card card-d border-danger"><div class="card-body p-4">
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i><strong>Esta accion no se puede deshacer.</strong></div>
    <table class="table table-bordered"><tr><th class="bg-light">Nombre</th><td>@Model.Nombre</td></tr><tr><th class="bg-light">Categoria</th><td>@(Model.Categoria?.Nombre??"-")</td></tr><tr><th class="bg-light">Precio</th><td>$@Model.Precio.ToString("N2")</td></tr><tr><th class="bg-light">Stock</th><td>@Model.Stock</td></tr></table>
    <form asp-action="Delete" method="post" class="d-flex gap-2">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i>Si, eliminar</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form>
</div></div></div></div>