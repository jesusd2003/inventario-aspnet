@model IEnumerable<InventarioApp.Models.Producto>
@{ ViewData["Title"]="Productos"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-archive"></i>Productos</h1>
        <p class="page-subtitle">Gestiona tu inventario de productos</p>
    </div>
    <a asp-action="Create" class="btn btn-modern-primary">
        <i class="bi bi-plus-lg me-2"></i>Nuevo Producto
    </a>
</div>

@if ((int)(ViewBag.StockBajo??0) > 0) {
    <div class="alert alert-modern alert-modern-warning mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>
            <strong>Atencion:</strong> Tienes @ViewBag.StockBajo producto(s) con stock menor a 5 unidades.
        </div>
    </div>
}

<!-- Search Box -->
<div class="card-modern mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="search-box">
            <div class="input-group-modern flex-grow-1">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="q" value="@ViewBag.Q" class="form-control" placeholder="Buscar producto por nombre..."/>
            </div>
            <button type="submit" class="btn btn-modern-dark">
                <i class="bi bi-search me-1"></i>Buscar
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Q as string)) {
                <a asp-action="Index" class="btn btn-modern-outline">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

<!-- Products Table -->
<div class="card-modern">
    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-archive"></i>
            </div>
            <h5 class="empty-state-title">No hay productos registrados</h5>
            <p class="empty-state-text">Comienza agregando tu primer producto al inventario</p>
            <a asp-action="Create" class="btn btn-modern-primary">
                <i class="bi bi-plus-lg me-2"></i>Crear Producto
            </a>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Producto</th>
                        <th>Categoria</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center" style="width:140px">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model) {
                        <tr class="@(p.StockBajo?"row-warning":"")">
                            <td class="text-muted fw-medium">@p.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="product-icon">
                                        <i class="bi bi-box-seam"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@p.Nombre</div>
                                        @if(p.StockBajo){
                                            <span class="badge badge-modern badge-danger">
                                                <i class="bi bi-exclamation-circle me-1"></i>Stock bajo
                                            </span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-modern badge-secondary">@(p.Categoria?.Nombre??"-")</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">$@p.Precio.ToString("N2")</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-modern @(p.StockBajo?"badge-danger":"badge-success") fs-6">
                                    @p.Stock
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-action btn-action-edit" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-action btn-action-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer">
            <i class="bi bi-info-circle me-1"></i>
            Mostrando @Model.Count() producto(s)
        </div>
    }
</div>

<style>
    .product-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(79, 70, 229, 0.05) 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.1rem;
    }
</style>
