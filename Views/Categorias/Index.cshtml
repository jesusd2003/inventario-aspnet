@model IEnumerable<InventarioApp.Models.Categoria>
@{ ViewData["Title"]="Categorias"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2 class="fw-bold mb-0"><i class="bi bi-tags me-2"></i>Categorias</h2></div><a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg me-1"></i>Nueva</a></div>
<div class="card card-d"><div class="card-body p-0">
    @if (!Model.Any()) { <div class="text-center py-5"><i class="bi bi-tags fs-1 text-muted"></i><p class="text-muted mt-2">Sin categorias. <a asp-action="Create">Crea la primera.</a></p></div> }
    else {
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark"><tr><th>#</th><th>Nombre</th><th class="text-center">Productos</th><th class="text-center">Acciones</th></tr></thead>
            <tbody>@foreach(var c in Model){<tr><td class="text-muted small">@c.Id</td><td class="fw-semibold">@c.Nombre</td><td class="text-center"><span class="badge bg-primary rounded-pill">@c.Productos.Count</span></td><td class="text-center"><a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a><a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a></td></tr>}</tbody>
        </table>
        <div class="px-3 py-2 border-top text-muted small">@Model.Count() categoria(s)</div>
    }
</div></div>