@model IEnumerable<InventarioApp.Models.Venta>
@{ ViewData["Title"]="Historial de Ventas"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-receipt"></i>Historial de Ventas</h1>
        <p class="page-subtitle">Visualiza todas las ventas registradas</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Reportes" class="btn btn-modern-outline">
            <i class="bi bi-bar-chart-line me-1"></i>Reportes
        </a>
        <a asp-action="Create" class="btn btn-modern-primary">
            <i class="bi bi-plus-lg me-2"></i>Nueva Venta
        </a>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-4 mb-3 mb-md-0">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-calendar-day"></i></div>
            <div class="stat-label">Ventas Hoy</div>
            <div class="stat-value">$@(((decimal)(ViewBag.TotalHoy??0m)).ToString("N2"))</div>
        </div>
    </div>
    <div class="col-md-4 mb-3 mb-md-0">
        <div class="stat-card success">
            <div class="stat-icon"><i class="bi bi-calendar-month"></i></div>
            <div class="stat-label">Ventas este Mes</div>
            <div class="stat-value">$@(((decimal)(ViewBag.TotalMes??0m)).ToString("N2"))</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card secondary">
            <div class="stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="stat-label">Total General</div>
            <div class="stat-value" style="color: var(--text-primary);">$@(((decimal)(ViewBag.TotalGeneral??0m)).ToString("N2"))</div>
        </div>
    </div>
</div>

<!-- Sales Table -->
<div class="card-modern">
    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-receipt"></i>
            </div>
            <h5 class="empty-state-title">No hay ventas registradas</h5>
            <p class="empty-state-text">Comienza registrando tu primera venta</p>
            <a asp-action="Create" class="btn btn-modern-primary">
                <i class="bi bi-plus-lg me-2"></i>Registrar Venta
            </a>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th class="text-center">Tipo Venta</th>
                        <th class="text-center">Tipo Pago</th>
                        <th class="text-center">Items</th>
                        <th class="text-end">Total</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model) {
                        <tr>
                            <td class="text-muted fw-medium">@v.Id</td>
                            <td>
                                <div class="fw-semibold">@v.Fecha.ToString("dd/MM/yyyy")</div>
                                <small class="text-muted">@v.Fecha.ToString("HH:mm")</small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="client-avatar">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <span class="fw-semibold">@(v.Cliente?.Nombre??"-")</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-modern @(v.TipoVenta==TipoVenta.POS?"badge-pos":"badge-directa")">
                                    @v.TipoVenta
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-modern @(v.TipoPago==TipoPago.Contado?"badge-contado":"badge-credito")">
                                    @v.TipoPago
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-modern badge-secondary">@v.Detalles.Count</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success fs-6">$@v.Total.ToString("N2")</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-action btn-action-view" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .client-avatar {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.1) 0%, rgba(14, 165, 233, 0.05) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--secondary);
        font-size: 0.9rem;
    }
</style>
