@model InventarioApp.Models.Venta
@{ ViewData["Title"]="Venta #"+Model.Id; }
<div class="d-flex align-items-center mb-4"><a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a><h2 class="fw-bold mb-0">Venta #@Model.Id</h2></div>
<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card card-d h-100"><div class="card-body p-4">
            <h5 class="fw-bold mb-3">Informacion</h5>
            <table class="table table-borderless table-sm">
                <tr><td class="text-muted">Fecha</td><td class="fw-bold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</td></tr>
                <tr><td class="text-muted">Cliente</td><td class="fw-bold">@(Model.Cliente?.Nombre??"-")</td></tr>
                <tr><td class="text-muted">Tipo Venta</td><td><span class="badge @(Model.TipoVenta==TipoVenta.POS?"badge-pos":"badge-directa")">@Model.TipoVenta</span></td></tr>
                <tr><td class="text-muted">Tipo Pago</td><td><span class="badge @(Model.TipoPago==TipoPago.Contado?"badge-contado":"badge-credito")">@Model.TipoPago</span></td></tr>
                <tr><td class="text-muted">Notas</td><td>@(Model.Notas??"-")</td></tr>
                <tr><td class="text-muted">Total</td><td class="fw-bold text-success fs-5">$@Model.Total.ToString("N2")</td></tr>
            </table>
        </div></div>
    </div>
    <div class="col-md-8 mb-4">
        <div class="card card-d"><div class="card-body p-0">
            <div class="px-4 py-3 border-bottom fw-bold"><i class="bi bi-cart me-2"></i>Productos</div>
            <table class="table align-middle mb-0">
                <thead class="table-light"><tr><th>Producto</th><th class="text-center">Cantidad</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th></tr></thead>
                <tbody>@foreach(var d in Model.Detalles){<tr><td class="fw-semibold">@(d.Producto?.Nombre??"-")</td><td class="text-center"><span class="badge bg-primary rounded-pill">@d.Cantidad</span></td><td class="text-end">$@d.PrecioUnitario.ToString("N2")</td><td class="text-end fw-bold text-success">$@d.Subtotal.ToString("N2")</td></tr>}</tbody>
                <tfoot><tr class="table-light"><td colspan="3" class="text-end fw-bold">TOTAL</td><td class="text-end fw-bold text-success fs-5">$@Model.Total.ToString("N2")</td></tr></tfoot>
            </table>
        </div></div>
    </div>
</div>