@model InventarioApp.Models.Venta
@{ ViewData["Title"]="Venta #"+Model.Id; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title mb-0"><i class="bi bi-receipt-cutoff"></i>Venta #@Model.Id</h1>
        <p class="page-subtitle mb-0">Detalles de la transaccion</p>
    </div>
</div>

<div class="row">
    <!-- Sale Info Card -->
    <div class="col-lg-4 mb-4">
        <div class="card-modern h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-info-circle text-primary"></i>
                <span class="fw-bold">Informacion de la Venta</span>
            </div>
            <div class="card-body">
                <div class="info-list">
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-calendar3 me-2"></i>Fecha</span>
                        <span class="info-value fw-bold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-person me-2"></i>Cliente</span>
                        <span class="info-value fw-semibold">@(Model.Cliente?.Nombre??"-")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-shop me-2"></i>Tipo Venta</span>
                        <span class="badge badge-modern @(Model.TipoVenta==TipoVenta.POS?"badge-pos":"badge-directa")">@Model.TipoVenta</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-credit-card me-2"></i>Tipo Pago</span>
                        <span class="badge badge-modern @(Model.TipoPago==TipoPago.Contado?"badge-contado":"badge-credito")">@Model.TipoPago</span>
                    </div>
                    @if(!string.IsNullOrEmpty(Model.Notas)) {
                        <div class="info-row flex-column align-items-start">
                            <span class="info-label mb-1"><i class="bi bi-sticky me-2"></i>Notas</span>
                            <span class="info-value text-muted">@Model.Notas</span>
                        </div>
                    }
                </div>
                
                <hr class="my-4"/>
                
                <div class="total-display">
                    <span class="total-display-label">Total de la venta</span>
                    <span class="total-display-value">$@Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Products Card -->
    <div class="col-lg-8 mb-4">
        <div class="card-modern">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-cart text-primary"></i>
                <span class="fw-bold">Productos Vendidos</span>
                <span class="badge badge-modern badge-primary ms-auto">@Model.Detalles.Count items</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-modern mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var d in Model.Detalles) {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="product-icon-sm">
                                                <i class="bi bi-box-seam"></i>
                                            </div>
                                            <span class="fw-semibold">@(d.Producto?.Nombre??"-")</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-modern badge-primary fs-6">@d.Cantidad</span>
                                    </td>
                                    <td class="text-end text-muted">$@d.PrecioUnitario.ToString("N2")</td>
                                    <td class="text-end fw-bold text-success">$@d.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background: var(--body-bg);">
                                <td colspan="3" class="text-end fw-bold py-3">TOTAL:</td>
                                <td class="text-end fw-bold text-success fs-5 py-3">$@Model.Total.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        background: var(--body-bg);
        border-radius: 10px;
    }
    
    .info-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }
    
    .info-value {
        color: var(--text-primary);
    }
    
    .total-display {
        background: linear-gradient(135deg, var(--dark) 0%, #1e293b 100%);
        border-radius: 14px;
        padding: 1.25rem;
        text-align: center;
    }
    
    .total-display-label {
        display: block;
        color: rgba(255,255,255,0.7);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }
    
    .total-display-value {
        font-size: 2rem;
        font-weight: 800;
        color: #10b981;
    }
    
    .product-icon-sm {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(79, 70, 229, 0.05) 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
    }
</style>
