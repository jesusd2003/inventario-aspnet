@model IEnumerable<InventarioApp.Models.Compra>
@{ ViewData["Title"]="Historial de Compras"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="fw-bold mb-0"><i class="bi bi-cart3 me-2"></i>Compras</h2><p class="text-muted small mb-0">Registro de compras a proveedores (suma al inventario)</p></div>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg me-1"></i>Nueva Compra</a>
</div>
<div class="card card-d"><div class="card-body p-0">
    @if (!Model.Any()) { <div class="text-center py-5"><i class="bi bi-cart3 fs-1 text-muted"></i><p class="text-muted mt-2">Sin compras. <a asp-action="Create">Registra la primera.</a></p></div> }
    else {
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark"><tr><th>#</th><th>Fecha</th><th>Proveedor</th><th class="text-center">Items</th><th class="text-end">Total Costo</th><th></th></tr></thead>
            <tbody>
            @foreach (var c in Model) {
                <tr>
                    <td class="text-muted small">@c.Id</td>
                    <td>@c.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(c.Proveedor??"-")</td>
                    <td class="text-center"><span class="badge bg-secondary">@c.Detalles.Count</span></td>
                    <td class="text-end fw-bold">$@c.Total.ToString("N2")</td>
                    <td><a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-dark"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</div></div>