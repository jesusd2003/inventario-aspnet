@model IEnumerable<InventarioApp.Models.Compra>
@{ ViewData["Title"]="Historial de Compras"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-cart3"></i>Historial de Compras</h1>
        <p class="page-subtitle">Registro de compras a proveedores (incrementa inventario)</p>
    </div>
    <a asp-action="Create" class="btn btn-modern-primary">
        <i class="bi bi-plus-lg me-2"></i>Nueva Compra
    </a>
</div>

<div class="card-modern">
    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-cart3"></i>
            </div>
            <h5 class="empty-state-title">No hay compras registradas</h5>
            <p class="empty-state-text">Las compras incrementan automaticamente el stock de productos</p>
            <a asp-action="Create" class="btn btn-modern-primary">
                <i class="bi bi-plus-lg me-2"></i>Registrar Compra
            </a>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Fecha</th>
                        <th>Proveedor</th>
                        <th class="text-center">Items</th>
                        <th class="text-end">Total Costo</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model) {
                        <tr>
                            <td class="text-muted fw-medium">@c.Id</td>
                            <td>
                                <div class="fw-semibold">@c.Fecha.ToString("dd/MM/yyyy")</div>
                                <small class="text-muted">@c.Fecha.ToString("HH:mm")</small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="provider-icon">
                                        <i class="bi bi-truck"></i>
                                    </div>
                                    <span class="fw-semibold">@(c.Proveedor??"-")</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-modern badge-secondary">@c.Detalles.Count</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold">$@c.Total.ToString("N2")</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-action btn-action-view" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .provider-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--success);
    }
</style>
