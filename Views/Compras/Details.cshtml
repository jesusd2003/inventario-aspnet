@model InventarioApp.Models.Compra
@{ ViewData["Title"]="Compra #"+Model.Id; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title mb-0"><i class="bi bi-receipt-cutoff"></i>Compra #@Model.Id</h1>
        <p class="page-subtitle mb-0">Detalles de la compra a proveedor</p>
    </div>
</div>

<div class="row">
    <!-- Purchase Info Card -->
    <div class="col-lg-4 mb-4">
        <div class="card-modern h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-info-circle text-success"></i>
                <span class="fw-bold">Informacion de la Compra</span>
            </div>
            <div class="card-body">
                <div class="info-list">
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-calendar3 me-2"></i>Fecha</span>
                        <span class="info-value fw-bold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label"><i class="bi bi-truck me-2"></i>Proveedor</span>
                        <span class="info-value fw-semibold">@(Model.Proveedor??"-")</span>
                    </div>
                    @if(!string.IsNullOrEmpty(Model.Notas)) {
                        <div class="info-row flex-column align-items-start">
                            <span class="info-label mb-1"><i class="bi bi-sticky me-2"></i>Notas</span>
                            <span class="info-value text-muted">@Model.Notas</span>
                        </div>
                    }
                </div>
                
                <hr class="my-4"/>
                
                <div class="total-display" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                    <span class="total-display-label">Total de la compra</span>
                    <span class="total-display-value" style="color: #fff;">$@Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Products Card -->
    <div class="col-lg-8 mb-4">
        <div class="card-modern">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-box text-success"></i>
                <span class="fw-bold">Productos Comprados</span>
                <span class="badge badge-modern badge-success ms-auto">@Model.Detalles.Count items</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-modern mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Costo Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var d in Model.Detalles) {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="product-icon-sm" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%); color: var(--success);">
                                                <i class="bi bi-box-seam"></i>
                                            </div>
                                            <span class="fw-semibold">@(d.Producto?.Nombre??"-")</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-modern badge-success fs-6">+@d.Cantidad</span>
                                    </td>
                                    <td class="text-end text-muted">$@d.CostoUnitario.ToString("N2")</td>
                                    <td class="text-end fw-bold">$@d.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background: var(--body-bg);">
                                <td colspan="3" class="text-end fw-bold py-3">TOTAL:</td>
                                <td class="text-end fw-bold fs-5 py-3">$@Model.Total.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        background: var(--body-bg);
        border-radius: 10px;
    }
    
    .info-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }
    
    .info-value {
        color: var(--text-primary);
    }
    
    .total-display {
        border-radius: 14px;
        padding: 1.25rem;
        text-align: center;
    }
    
    .total-display-label {
        display: block;
        color: rgba(255,255,255,0.8);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }
    
    .total-display-value {
        font-size: 2rem;
        font-weight: 800;
    }
    
    .product-icon-sm {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
