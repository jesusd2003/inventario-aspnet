@model InventarioApp.Models.Cliente
@{ ViewData["Title"]="Eliminar Cliente"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title mb-0" style="color: var(--danger);">
            <i class="bi bi-trash"></i>Eliminar Cliente
        </h1>
        <p class="page-subtitle mb-0">Confirma la eliminacion del cliente</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card-modern" style="border: 2px solid rgba(239, 68, 68, 0.2);">
            <div class="card-body p-4 p-lg-5">
                @if(Model.Ventas.Any()) {
                    <div class="alert alert-modern alert-modern-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <div>
                            Este cliente tiene <strong>@Model.Ventas.Count venta(s)</strong> registradas. No se puede eliminar.
                        </div>
                    </div>
                    
                    <div class="client-preview text-center mb-4">
                        <div class="client-avatar-delete mx-auto mb-3">
                            @Model.Nombre.Substring(0,1).ToUpper()
                        </div>
                        <h5 class="fw-bold mb-1">@Model.Nombre</h5>
                        <p class="text-muted mb-0">@(Model.Telefono??"-")</p>
                    </div>
                    
                    <a asp-action="Index" class="btn btn-modern-outline w-100">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </a>
                } else {
                    <div class="alert alert-modern alert-modern-warning mb-4">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <div>
                            <strong>Atencion:</strong> Esta accion no se puede deshacer.
                        </div>
                    </div>
                    
                    <div class="client-preview text-center mb-4">
                        <div class="client-avatar-delete mx-auto mb-3">
                            @Model.Nombre.Substring(0,1).ToUpper()
                        </div>
                        <h5 class="fw-bold mb-1">@Model.Nombre</h5>
                        <p class="text-muted mb-0">@(Model.Telefono??"-")</p>
                    </div>
                    
                    <hr class="my-4"/>
                    
                    <form asp-action="Delete" method="post" class="d-flex gap-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger flex-grow-1" style="border-radius: 10px; font-weight: 600; padding: 0.75rem;">
                            <i class="bi bi-trash me-2"></i>Si, Eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-modern-outline">
                            Cancelar
                        </a>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .client-avatar-delete {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.2) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--danger);
        font-weight: 700;
        font-size: 1.75rem;
    }
</style>
