@model InventarioApp.Models.Cliente
@{ ViewData["Title"]="Historial de " + Model.Nombre; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div class="d-flex align-items-center gap-3">
        <div class="client-avatar-lg">
            @Model.Nombre.Substring(0,1).ToUpper()
        </div>
        <div>
            <h1 class="page-title mb-0">@Model.Nombre</h1>
            <p class="page-subtitle mb-0">
                <i class="bi bi-telephone me-1"></i>@(Model.Telefono??"Sin telefono")
            </p>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-6 col-lg-3 mb-3 mb-lg-0">
        <div class="stat-card secondary">
            <div class="stat-icon"><i class="bi bi-receipt"></i></div>
            <div class="stat-label">Total Compras</div>
            <div class="stat-value" style="color: var(--text-primary);">@Model.Ventas.Count</div>
        </div>
    </div>
    <div class="col-6 col-lg-3 mb-3 mb-lg-0">
        <div class="stat-card success">
            <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-label">Total Gastado</div>
            <div class="stat-value">$@Model.Ventas.Sum(v=>v.Total).ToString("N2")</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-cash"></i></div>
            <div class="stat-label">Compras Contado</div>
            <div class="stat-value">@Model.Ventas.Count(v=>v.TipoPago==TipoPago.Contado)</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card warning">
            <div class="stat-icon"><i class="bi bi-credit-card"></i></div>
            <div class="stat-label">Compras Credito</div>
            <div class="stat-value">@Model.Ventas.Count(v=>v.TipoPago==TipoPago.Credito)</div>
        </div>
    </div>
</div>

<!-- Purchase History -->
<div class="card-modern">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="bi bi-receipt text-primary"></i>
        <span class="fw-bold">Historial de Compras</span>
    </div>
    @if (!Model.Ventas.Any()) {
        <div class="empty-state py-5">
            <div class="empty-state-icon" style="width:60px;height:60px;">
                <i class="bi bi-receipt fs-4"></i>
            </div>
            <p class="text-muted">Este cliente no tiene compras registradas</p>
        </div>
    } else {
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th style="width:60px">#</th>
                            <th>Fecha</th>
                            <th class="text-center">Tipo Venta</th>
                            <th class="text-center">Tipo Pago</th>
                            <th class="text-center">Items</th>
                            <th class="text-end">Total</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Ventas.OrderByDescending(x=>x.Fecha)) {
                            <tr>
                                <td class="text-muted fw-medium">@v.Id</td>
                                <td>
                                    <div class="fw-semibold">@v.Fecha.ToString("dd/MM/yyyy")</div>
                                    <small class="text-muted">@v.Fecha.ToString("HH:mm")</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-modern @(v.TipoVenta==TipoVenta.POS?"badge-pos":"badge-directa")">@v.TipoVenta</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-modern @(v.TipoPago==TipoPago.Contado?"badge-contado":"badge-credito")">@v.TipoPago</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-modern badge-secondary">@v.Detalles.Count</span>
                                </td>
                                <td class="text-end fw-bold text-success">$@v.Total.ToString("N2")</td>
                                <td>
                                    <a asp-controller="Ventas" asp-action="Details" asp-route-id="@v.Id" class="btn btn-action btn-action-view" title="Ver detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .client-avatar-lg {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 1.5rem;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
    }
</style>
