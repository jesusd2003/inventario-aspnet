@model InventarioApp.Models.Cliente
@{ ViewData["Title"]="Historial de " + Model.Nombre; }
<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <div><h2 class="fw-bold mb-0"><i class="bi bi-person-circle me-2"></i>@Model.Nombre</h2><p class="text-muted small mb-0">@(Model.Telefono??"")</p></div>
</div>
<div class="row mb-4">
    <div class="col-md-3"><div class="card card-d text-center p-3"><div class="text-muted small">Total Compras</div><div class="fw-bold fs-4">@Model.Ventas.Count</div></div></div>
    <div class="col-md-3"><div class="card card-d text-center p-3"><div class="text-muted small">Total Gastado</div><div class="fw-bold fs-4 text-success">$@Model.Ventas.Sum(v=>v.Total).ToString("N2")</div></div></div>
    <div class="col-md-3"><div class="card card-d text-center p-3"><div class="text-muted small">Compras Contado</div><div class="fw-bold fs-4">@Model.Ventas.Count(v=>v.TipoPago==TipoPago.Contado)</div></div></div>
    <div class="col-md-3"><div class="card card-d text-center p-3"><div class="text-muted small">Compras Credito</div><div class="fw-bold fs-4 text-warning">@Model.Ventas.Count(v=>v.TipoPago==TipoPago.Credito)</div></div></div>
</div>
<div class="card card-d"><div class="card-body p-0">
    <div class="px-4 py-3 border-bottom fw-bold"><i class="bi bi-receipt me-2"></i>Historial de Ventas</div>
    @if (!Model.Ventas.Any()) { <div class="text-center py-4 text-muted">Este cliente no tiene ventas aun.</div> }
    else {
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr><th>#</th><th>Fecha</th><th>Tipo</th><th>Pago</th><th class="text-center">Items</th><th class="text-end">Total</th><th></th></tr></thead>
            <tbody>
            @foreach (var v in Model.Ventas.OrderByDescending(x=>x.Fecha)) {
                <tr>
                    <td class="text-muted small">@v.Id</td>
                    <td>@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="badge @(v.TipoVenta==TipoVenta.POS?"badge-pos":"badge-directa")">@v.TipoVenta</span></td>
                    <td><span class="badge @(v.TipoPago==TipoPago.Contado?"badge-contado":"badge-credito")">@v.TipoPago</span></td>
                    <td class="text-center">@v.Detalles.Count</td>
                    <td class="text-end fw-bold text-success">$@v.Total.ToString("N2")</td>
                    <td><a asp-controller="Ventas" asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-dark"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</div></div>