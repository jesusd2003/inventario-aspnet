@model InventarioApp.Models.Cliente
@{ ViewData["Title"]="Editar Cliente"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h1 class="page-title mb-0"><i class="bi bi-pencil-square"></i>Editar Cliente</h1>
        <p class="page-subtitle mb-0">Modifica la informacion de: <strong>@Model.Nombre</strong></p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-modern">
            <div class="card-body p-4 p-lg-5">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id"/>
                    
                    <div class="mb-4">
                        <label asp-for="Nombre" class="form-label-modern">
                            <i class="bi bi-person me-1"></i>Nombre completo
                        </label>
                        <input asp-for="Nombre" class="form-control form-control-modern"/>
                        <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Telefono" class="form-label-modern">
                            <i class="bi bi-telephone me-1"></i>Telefono (opcional)
                        </label>
                        <div class="input-group-modern">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input asp-for="Telefono" class="form-control"/>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Direccion" class="form-label-modern">
                            <i class="bi bi-geo-alt me-1"></i>Direccion (opcional)
                        </label>
                        <textarea asp-for="Direccion" class="form-control form-control-modern" rows="2"></textarea>
                    </div>
                    
                    <hr class="my-4"/>
                    
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-modern-primary px-4">
                            <i class="bi bi-check-lg me-2"></i>Guardar Cambios
                        </button>
                        <a asp-action="Index" class="btn btn-modern-outline">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
