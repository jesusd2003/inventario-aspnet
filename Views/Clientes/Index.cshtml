@model IEnumerable<InventarioApp.Models.Cliente>
@{ ViewData["Title"]="Clientes"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-people"></i>Clientes</h1>
        <p class="page-subtitle">Gestiona tu base de clientes</p>
    </div>
    <a asp-action="Create" class="btn btn-modern-primary">
        <i class="bi bi-plus-lg me-2"></i>Nuevo Cliente
    </a>
</div>

<div class="card-modern">
    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-people"></i>
            </div>
            <h5 class="empty-state-title">No hay clientes registrados</h5>
            <p class="empty-state-text">Comienza agregando tu primer cliente</p>
            <a asp-action="Create" class="btn btn-modern-primary">
                <i class="bi bi-plus-lg me-2"></i>Agregar Cliente
            </a>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Cliente</th>
                        <th>Telefono</th>
                        <th class="text-center">Compras</th>
                        <th class="text-end">Total Comprado</th>
                        <th class="text-center" style="width:160px">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model) {
                        <tr>
                            <td class="text-muted fw-medium">@c.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="client-avatar-table">
                                        @c.Nombre.Substring(0,1).ToUpper()
                                    </div>
                                    <span class="fw-semibold">@c.Nombre</span>
                                </div>
                            </td>
                            <td class="text-muted">@(c.Telefono??"-")</td>
                            <td class="text-center">
                                <span class="badge badge-modern badge-primary">@c.Ventas.Count</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-bold text-success">$@c.Ventas.Sum(v=>v.Total).ToString("N2")</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-action btn-action-view" title="Ver historial">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-action btn-action-edit" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-action btn-action-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer">
            <i class="bi bi-info-circle me-1"></i>
            Mostrando @Model.Count() cliente(s)
        </div>
    }
</div>

<style>
    .client-avatar-table {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
    }
</style>
